<UserControl x:Class="MyToDo.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MyToDo.Views"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="设置" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <!-- Theme -->
            <Border Margin="0,5" Padding="15" CornerRadius="5"
                    Background="{DynamicResource MaterialDesignCardBackground}">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="深色主题" FontSize="16" FontWeight="Medium"/>
                        <TextBlock Text="切换应用程序的深色/浅色外观" FontSize="12" Opacity="0.7"/>
                    </StackPanel>
                    <ToggleButton DockPanel.Dock="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding IsDarkTheme}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                </DockPanel>
            </Border>

            <!-- About -->
            <Border Margin="0,5" Padding="15" CornerRadius="5"
                    Background="{DynamicResource MaterialDesignCardBackground}">
                <StackPanel>
                    <TextBlock Text="关于" FontSize="16" FontWeight="Medium"/>
                    <TextBlock Text="MyToDo v1.0 — 一款简洁的待办事项与备忘录应用" FontSize="12" Opacity="0.7" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
